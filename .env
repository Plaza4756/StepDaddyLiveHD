PORT="3535"
# Replace with your local IP or domain if you want to access it across the network
API_URL="http://localhost:3535"
# Set to FALSE if you don't want to proxy content. Leave it TRUE in most cases
PROXY_CONTENT="TRUE"
# Add SOCKS5 proxy details for DLHD request if needed "user:password@proxy.example.com:1080"
SOCKS5=""
# Useful if you put the container behind vpn (i.e. gluetun) and there is a port conflict. Leave unchanged otherwise
BACKEND_PORT="8004"
